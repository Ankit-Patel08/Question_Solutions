#include<bits/stdc++.h>
using namespace std;

void permute(vector<int>&arr, vector<vector<int>>&ans, vector<bool>&used, vector<int>&curr, int n){
    if(curr.size() == n){
        ans.push_back(curr);
        return;
    }
    for(int i = 0; i<n; i++){
        if(used[i]) continue;
        
        used[i] = true;
        curr.push_back(arr[i]);
        
        permute(arr, ans,used, curr, n);
        
        used[i] = false;
        curr.pop_back();
    }
}


int main() {
    int n;
    cout<<"Enter the size of the array -> ";
    cin>>n;
    
    vector<int> arr(n);
    for(int i = 0; i<n; i++){
        cin>>arr[i];
    }
    vector<vector<int>> ans;
    vector<bool>used(n,false);
    vector<int>curr;
    
    permute(arr,ans,used,curr,n);
    
     for(auto &perm : ans){
        for(int x : perm){
            cout << x << " ";
        }
        cout << endl;
    }

    return 0;
}


// Approach 2
// More Optimized way of Approach 1 -> here we are saving the extra space whihc we were using in Approach 1
void permute(vector<int>&nums, int idx){
    if(idx == nums.size()){
        for(auto x : num) cout<<x<<" ";
        cout<<endl;
        return;
    }
    for(int i = idx; i<num.size(); i++){
        swap(nums[i], nums[idx]);
        permute(nums, idx+1);
        swap(nums[i], nums[idx]);
    }
}