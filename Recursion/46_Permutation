#include<bits/stdc++.h>
using namespace std;

void permute(vector<int>&arr, vector<vector<int>>&ans, vector<bool>&used, vector<int>&curr, int n){
    if(curr.size() == n){
        ans.push_back(curr);
        return;
    }
    for(int i = 0; i<n; i++){
        if(used[i]) continue;
        
        used[i] = true;
        curr.push_back(arr[i]);
        
        permute(arr, ans,used, curr, n);
        
        used[i] = false;
        curr.pop_back();
    }
}


int main() {
    int n;
    cout<<"Enter the size of the array -> ";
    cin>>n;
    
    vector<int> arr(n);
    for(int i = 0; i<n; i++){
        cin>>arr[i];
    }
    vector<vector<int>> ans;
    vector<bool>used(n,false);
    vector<int>curr;
    
    permute(arr,ans,used,curr,n);
    
     for(auto &perm : ans){
        for(int x : perm){
            cout << x << " ";
        }
        cout << endl;
    }

    return 0;
}




